    "version": "0.2.0",
    "configurations": [
        {
            "name": "Screenplay Parser (uvicorn --reload)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": ["main:app", "--reload"],
            "cwd": "${workspaceFolder}/apps/screenplay-parser",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/apps/screenplay-parser/.venv/bin/python"
        }
    ]
}