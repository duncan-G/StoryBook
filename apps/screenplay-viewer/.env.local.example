# Aspire dashboard OTLP HTTP endpoint (see infra/telemetry/aspire.stack.dev.yaml).
# Client (browser) sends traces to this URL; must be reachable from the browser (CORS allowed).
NEXT_PUBLIC_OTLP_HTTP_ENDPOINT=http://localhost:4318/v1

# Server-side: used by Next.js instrumentation (@vercel/otel). Aspire listens on 4318 for HTTP.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
