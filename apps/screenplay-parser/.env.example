# Database (Postgres + pgvector)
DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5432/dev

# OpenTelemetry — set to send traces and logs to Aspire dashboard (e.g. http://localhost:4318)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# CORS — comma-separated origins allowed for browser requests (default: http://localhost:3000,http://127.0.0.1:3000)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Gemini: embeddings (/ingest) and Q&A (/ask). Use either variable.
# GEMINI_API_KEY=your-key-here

# Q&A model cost ($ per 1M tokens; default: 0.10 input, 0.40 output for Gemini 2.5 Flash)
# QA_INPUT_COST_PER_MILLION_TOKENS=0.10
# QA_OUTPUT_COST_PER_MILLION_TOKENS=0.40
